{
  "name": "vue-timeline-component",
  "version": "0.2.3",
  "type": "module",
  "description": "A Vue 3 timeline component powered by D3.js",
  "main": "./dist/vue-timeline-component.umd.js",
  "module": "./dist/vue-timeline-component.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vue-timeline-component.es.js",
      "require": "./dist/vue-timeline-component.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "vite serve example --config vite.config.ts",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0xdv/vue-timeline-component"
  },
  "homepage": "https://github.com/0xdv/vue-timeline-component",
  "bugs": {
    "url": "https://github.com/0xdv/vue-timeline-component/issues"
  },
  "author": "0xdv <0xc0ffec0de@gmail.com>",
  "license": "MIT",
  "keywords": [
    "vue",
    "vue3",
    "timeline",
    "d3",
    "component",
    "chart",
    "visualization"
  ],
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "dependencies": {
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@vitejs/plugin-vue": "^5.1.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.0"
  }
}
